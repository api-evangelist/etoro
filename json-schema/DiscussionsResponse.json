{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/etoro/refs/heads/main/json-schema/DiscussionsResponse.json",
  "title": "DiscussionsResponse",
  "type": "object",
  "description": "Paginated feed response containing a list of discussions",
  "properties": {
    "discussions": {
      "type": "array",
      "items": {
        "$ref": "#/components/schemas/Discussion"
      }
    },
    "paging": {
      "type": "object",
      "description": "Pagination info",
      "properties": {
        "next": {
          "type": "string",
          "description": "URL to fetch the next page",
          "example": "/api/v1/feeds/user/7890?offset=20&take=20"
        },
        "offSet": {
          "type": "integer",
          "description": "Current page offset",
          "example": 0
        },
        "take": {
          "type": "integer",
          "description": "Page size used for this response",
          "example": 20
        },
        "version": {
          "type": "string",
          "description": "API version string",
          "example": "v1"
        }
      }
    },
    "metadata": {
      "type": "object",
      "description": "Feed-level metadata for analytics",
      "properties": {
        "experimentName": {
          "type": "string",
          "description": "Active A/B experiment name",
          "example": "ForYouRankingV2"
        },
        "streamType": {
          "type": "string",
          "description": "Actual stream/ranking type served",
          "example": "ForYou"
        },
        "designatedStreamType": {
          "type": "string",
          "description": "Intended stream type (may differ during A/B)",
          "example": "ForYou"
        }
      }
    }
  }
}